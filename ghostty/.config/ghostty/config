# ghostty-core
#
# Notes:
# Docs:
#   ghostty +show-config --default --docs | less
# search github for example configs
#   https://github.com/search?q=path%3Aghostty%2Fconfig&type=code
# How to reload config:
#   Linux: ctrl+shift+,
#   macOS: cmd+shift+,
# Generate a config
#   https://ghostty.zerebos.com/settings/application

# window splits
#split vertically (to right): cmd - d
#split horizontally (pane below): cmd - shift - d
# navigating between splits
#move focus to adjacent split: cmd + [ -or- cmd + ]
# window controls
#maximize/zoom a single pane: cmd + shift + enter
#(hides other panes temporarily so you can focus)
#close the current pane: cmd + w

# Default
command = /bin/zsh
click-repeat-interval = 500
auto-update-channel = stable

# Bell
# Disable audio and system beep bells
bell-features = no-system,no-audio
# Enable visual and window attention bells
bell-features = border,attention

# Theme: ghostty +list-themes
window-theme = auto
# catppuccin theme: Frappe / Latte / Macchiato / Mocha
theme = Ubuntu
#theme = "Catppuccin Macchiato"
#theme = Dracula
background-opacity = 0.94
background-blur-radius = 40

# Cursor
# shell integration sets the cursor to a bar at a prompt
shell-integration-features = no-cursor,sudo,title
cursor-style = block
cursor-style-blink = false
cursor-opacity = 0.7
cursor-invert-fg-bg = false
# linux: alt-click, macOS: option-click
cursor-click-to-move = true

# Scrollback limit in bytes
scrollback-limit = 10000000

# Set working directory, default inherits previous process
working-directory = home
# new tabs inherit the PWD
window-inherit-working-directory = false

# Fonts: ghostty +list-fonts
##font-family = Symbols Nerd Font Mono # messes with primary font
font-family = Monaco
font-size = 16
selection-invert-fg-bg = false
bold-is-bright = false
font-thicken = false

# macOS Specific
#macos-titlebar-style = tabs
macos-titlebar-proxy-icon = hidden
macos-option-as-alt = true
clipboard-read = allow
clipboard-write = allow
clipboard-trim-trailing-spaces = true
clipboard-paste-protection = false
macos-non-native-fullscreen = visible-menu
macos-window-shadow = true

# Quick Terminal animation duration (in seconds)
# Set to 0 to disable animation, can be changed at runtime.
quick-terminal-animation-duration = 0.08
quick-terminal-position = top
#window-save-state = never
window-save-state = default

# Notifications
notify-on-command-finish = unfocused

# Initial window width and height
window-height = 24
window-width = 80

# window padding
window-padding-x = 4,2
window-padding-y = 6,0
window-padding-balance = true

# quit app after closing last window
quit-after-last-window-closed = false

# Mouse
mouse-hide-while-typing = true
# mouse-scroll-multiplier = 1
# focus-follows-mouse = false

# Right Click context menu
#right-click-action = paste
right-click-action = ignore
#mouse-reporting = true

# Key Bindings remap toggle_quick_term to avoid app window switch key)
#keybind = global:super+grave_accent=toggle_quick_terminal
keybind = global:alt+grave_accent=toggle_quick_terminal
keybind = shift+ctrl+left_bracket=previous_tab
keybind = shift+ctrl+right_bracket=next_tab

# Override ghostty terminal
term = xterm-256color

# OS Specific settings (manage through stow, ex: stow ghostty-macos)
config-file = ? macos.conf
config-file = ? linux.conf
config-file = ? local.conf
